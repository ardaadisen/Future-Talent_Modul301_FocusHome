# Copy this file to `.env` for local development. Never commit `.env` or real secrets.

# --- Auth mode ---
# AUTH_MODE: local (default, optional auth) | supabase (JWT required) | mock (dev only)
AUTH_MODE=local

# --- Supabase (required when AUTH_MODE=supabase) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# JWT secret from Supabase project settings → API → JWT Settings
SUPABASE_JWT_SECRET=

# --- Optional cloud database (future) ---
DATABASE_URL=

# --- AI task parsing (optional) ---
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
AI_HTTP_TIMEOUT_SECONDS=15
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Server ---
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
