# Copy this file to `.env` for local development. Never commit `.env` or real secrets.

# --- Auth mode ---
# supabase: production — verified Supabase JWT required for protected endpoints
# local: optional sign-in; JWT verified when SUPABASE_JWT_SECRET is set
# mock: development only (AUTH_MODE=mock + APP_ENV=development)
AUTH_MODE=supabase

# --- Supabase (backend-only — never expose service role to frontend) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# JWT secret from Supabase → Project Settings → API → JWT Settings
SUPABASE_JWT_SECRET=

# --- Supabase Postgres (required for signed-in cloud persistence) ---
# Session pooler URI from Supabase → Project Settings → Database
# Example shape (replace placeholders):
# postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=

# --- AI task parsing (optional — Smart Parse fallback when key missing) ---
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
AI_HTTP_TIMEOUT_SECONDS=15
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Server ---
# development | production (production disables mock auth and verbose error details)
APP_ENV=development

# Comma-separated browser origins allowed to call the API (no trailing slashes)
# Local dev:
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
# Production — add your Vercel URL, e.g.:
# CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5173
