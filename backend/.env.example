# Copy this file to `.env` for local development. Never commit `.env` or real secrets.

# --- Auth mode ---
# local: optional sign-in; JWT verified when SUPABASE_JWT_SECRET is set
# supabase: production — only verified account tokens accepted
# mock: development only (AUTH_MODE=mock + APP_ENV=development)
AUTH_MODE=supabase

# --- Supabase (backend-only — never expose service role to frontend) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# JWT secret from Supabase project settings → API → JWT Settings
SUPABASE_JWT_SECRET=

# --- Supabase Postgres (required for signed-in cloud persistence) ---
# Connection string from Supabase → Project Settings → Database (Session pooler URI)
# Example: postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=

# --- AI task parsing (optional) ---
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
AI_HTTP_TIMEOUT_SECONDS=15
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Server ---
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
