# Copy this file to `.env` for local development. Never commit `.env` or real secrets.
# Vite exposes only variables prefixed with VITE_.

# --- Backend connection (optional in local-only mode; needed for AI parse and account sync) ---
VITE_API_BASE_URL=http://127.0.0.1:8000

# --- Account sync (optional — app works fully on this device without these) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Optional dev sign-in mock (development only) ---
# VITE_ENABLE_MOCK_AUTH=true
