# Copy this file to `.env` for local development. Never commit `.env` or real secrets.
# Vite exposes only variables prefixed with VITE_.

# --- Backend API (required for AI parse and cloud sync) ---
# Local:
VITE_API_BASE_URL=http://127.0.0.1:8000
# Production (Vercel) — set to your Render backend URL, e.g.:
# VITE_API_BASE_URL=https://your-api.onrender.com

# --- Supabase Auth (optional — app works fully on this device without these) ---
# From Supabase → Project Settings → API (anon public key only — never service role)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Optional dev sign-in mock (development only, no Supabase) ---
# VITE_ENABLE_MOCK_AUTH=true
